# انسخ هذا الملف إلى .env واملأ القيم. (لا ترفع .env إلى GitHub أبداً)

# منفذ الخادم (Render يحدّده تلقائياً)
PORT=8787

# سرّ توقيع الجلسات — إجباري وقوي (32 حرفاً عشوائياً على الأقل).
# الخادم يرفض الإقلاع إذا كان ناقصاً أو ضعيفاً.
JWT_SECRET=

# رابط قاعدة بيانات PostgreSQL (Neon)
DATABASE_URL=

# مفتاح fal.ai للتوليد — https://fal.ai/dashboard/keys
FAL_KEY=

# مفتاح Anthropic لتحسين الوصف — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# مفتاح Resend لإرسال بريد التأكيد — https://resend.com/
RESEND_API_KEY=
# اسم وعنوان المُرسِل (نطاق مفعّل في Resend)
MAIL_FROM=Tayf <no-reply@tayf.art>

# عدد العملات المجانية لكل حساب جديد بعد تأكيد البريد
FREE_CREDITS=3

# إيميلات الأدمن (مفصولة بفاصلة) — فقط هذه الحسابات تدخل لوحة التحكم
ADMIN_EMAILS=tayff.art@gmail.com

# عنوان الخادم العام (يُستخدم في رابط تأكيد البريد)
APP_URL=https://tayf-backend.onrender.com
