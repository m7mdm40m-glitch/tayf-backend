# انسخ هذا الملف إلى .env واملأ القيم

# منفذ الخادم
PORT=8787

# سرّ توقيع الجلسات (اكتب نصاً عشوائياً طويلاً)
JWT_SECRET=change-me-to-a-long-random-string

# مفتاح fal.ai — احصل عليه من https://fal.ai/dashboard/keys (يتطلب بطاقة، التوليد مدفوع بالثانية)
FAL_KEY=

# مفتاح Anthropic لتحسين الوصف — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# عدد العملات المجانية لكل حساب جديد
FREE_CREDITS=3

# عنوان الواجهة المسموح لها بالاتصال (CORS)
CLIENT_ORIGIN=http://localhost:5173

# عنوان الخادم العام (يُستخدم في رابط تأكيد البريد)
APP_URL=http://localhost:8787

# إعدادات إرسال بريد التأكيد (اتركها فارغة أثناء التطوير فيُطبع الرابط في الطرفية)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Tayf <no-reply@tayf.app>
